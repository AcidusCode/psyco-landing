---
import Image from "astro/components/Image.astro";
import PageSubtitle from "../molecules/PageSubtitle.astro";
import PsicologistGraphic from "../../assets/image/psicologist-graphic.png";
import IconCard from "../molecules/cards/IconCard.astro";
import Section from "./Section.astro";
---

<Section>
  <PageSubtitle
    lead="Sanar desde adentro"
    heading="Para quién es esta terapia"
    body="Si sientes que tus emociones te desbordan o te cuesta gestionar tus \n vínculos, este es un espacio seguro para reencontrarte y sanar."
    align="center"
  />

  <div class="flex items-center flex-col lg:flex-row gap-20 lg:gap-40">
    <Image src={PsicologistGraphic} alt="Imagen de cabeza confundida" />
    <div class="flex flex-col gap-16">
      <IconCard
        heading="Ansiedad o estrés"
        body="Personas con ansiedad, agotamiento \n o estrés constante."
        nameIcon="icon-alert"
      />
      <IconCard
        heading="Heridas emocionales"
        body="Personas que desean sanar heridas \n emocionales o experiencias difíciles."
        nameIcon="icon-shield"
      />
      <IconCard
        heading="Ansiedad o estrés"
        body="Personas que buscan mejorar relaciones, \n límites, autoestima o manejo emocional."
        nameIcon="icon-fire"
      />
    </div>
  </div>
</Section>
