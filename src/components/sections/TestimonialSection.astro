---
import TestimonialCard from "../molecules/cards/TestimonialCard.astro";
import PageSubtitle from "../molecules/PageSubtitle.astro";
import Section from "./Section.astro";
import Button from "../atoms/Button.astro";
import Paragraph from "../typography/body/Paragraph.astro";

import testimonialData from "../../data/testimonials/testimonialData.json";

const topRow = testimonialData.filter((_, index) => index % 2 === 0);
const bottomRow = testimonialData.filter((_, index) => index % 2 !== 0);
---

<Section>
  <PageSubtitle
    lead="Testimonios"
    heading="Lo que dicen"
    body="Experiencia real de personas que encontraron claridad y paz mental."
    align="center"
    highlight="mis clientes"
  />
  <div class="testimonial-marquee">
    <div class="marquee-row">
      <div class="marquee-track marquee-track-left">
        <div class="marquee-group">
          {
            topRow.map((testimonial) => (
              <TestimonialCard
                image={testimonial.testimonialImage}
                name={testimonial.name}
                service={testimonial.service}
                rating={testimonial.rating}
                countryIcon={testimonial.countryIcon}
                quote={testimonial.quote.slice(0, 120)}
              />
            ))
          }
        </div>
        <div class="marquee-group" aria-hidden="true">
          {
            topRow.map((testimonial) => (
              <TestimonialCard
                image={testimonial.testimonialImage}
                name={testimonial.name}
                service={testimonial.service}
                rating={testimonial.rating}
                countryIcon={testimonial.countryIcon}
                quote={testimonial.quote.slice(0, 120)}
              />
            ))
          }
        </div>
      </div>
    </div>

    <div class="marquee-row">
      <div class="marquee-track marquee-track-right">
        <div class="marquee-group">
          {
            bottomRow.map((testimonial) => (
              <TestimonialCard
                image={testimonial.testimonialImage}
                name={testimonial.name}
                service={testimonial.service}
                rating={testimonial.rating}
                countryIcon={testimonial.countryIcon}
                quote={testimonial.quote.slice(0, 120)}
              />
            ))
          }
        </div>
        <div class="marquee-group" aria-hidden="true">
          {
            bottomRow.map((testimonial) => (
              <TestimonialCard
                image={testimonial.testimonialImage}
                name={testimonial.name}
                service={testimonial.service}
                rating={testimonial.rating}
                countryIcon={testimonial.countryIcon}
                quote={testimonial.quote.slice(0, 120)}
              />
            ))
          }
        </div>
      </div>
    </div>
  </div>
  <div class="flex flex-col gap-8">
    <Paragraph
      size="lg"
      text=" ¡TÚ PODRÍAS SER EL SIGUIENTE!"
      align="center"
      color="text-neutral-100"
    />
    <Button
      label="Conoce más tertimonios"
      iconRight="icon-right-arrow"
      variant="solid"
      size="lg"
      intent="primary"
    />
  </div>
</Section>

<style>
  .testimonial-marquee {
    --marquee-gap: var(--spacing-800);
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-600);
  }

  .marquee-row {
    position: relative;
    padding: var(--spacing-400) 0;
    overflow: hidden;
    width: 100%;
    mask-image: linear-gradient(
      to right,
      transparent,
      rgba(0, 0, 0, 1) 8%,
      rgba(0, 0, 0, 1) 92%,
      transparent
    );
  }

  .marquee-track {
    width: max-content;
    display: flex;
    flex-wrap: nowrap;
    will-change: transform;
  }

  .marquee-group {
    display: flex;
    flex-wrap: nowrap;
    gap: var(--marquee-gap);
    padding-right: var(--marquee-gap);
  }

  .marquee-track-left {
    animation: testimonial-marquee-left 40s linear infinite;
  }

  .marquee-track-right {
    animation: testimonial-marquee-right 46s linear infinite;
  }

  @keyframes testimonial-marquee-left {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @keyframes testimonial-marquee-right {
    from {
      transform: translateX(-50%);
    }
    to {
      transform: translateX(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track-left,
    .marquee-track-right {
      animation: none;
      transform: translateX(0);
    }
  }
</style>
