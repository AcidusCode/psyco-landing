---
import ServiceCard from "../molecules/cards/ServiceCard.astro";
import PageSubtitle from "../molecules/PageSubtitle.astro";
import Section from "./Section.astro";
import Button from "../atoms/Button.astro";

import serviceData from "../../data/services/servicesData.json";
---

<Section class="py-25 md:py-20 max-md:py-14">
  <div class="service-section-root max-w-7xl w-full px-6 md:px-5 max-md:px-4">
    <div class="service-anim-item">
      <PageSubtitle
        lead="Atención psicológica personalizada"
        heading="Atención especializada para"
        highlight="tus necesidades"
        body="Enfoques terapéuticos personalizados para ayudarte a superar desafíos y prosperar"
      />
    </div>
    <div class="flex flex-col my-16 md:my-12 max-md:my-8 gap-10 md:gap-7 max-md:gap-5">
      <div class="grid grid-cols-2 max-md:grid-cols-1 gap-10 md:gap-6 max-md:gap-4">
        {
          serviceData
            .slice(0, 2)
            .map((service) => (
              <div class="service-card-anim-item h-full">
                <ServiceCard
                  image={service.image}
                  title={service.title}
                  lead={service.lead}
                  description={service.description}
                />
              </div>
            ))
        }
      </div>
      <div class="grid grid-cols-3 md:grid-cols-2 max-md:grid-cols-1 gap-10 md:gap-6 max-md:gap-4">
        {
          serviceData
            .slice(2)
            .map((service) => (
              <div class="service-card-anim-item h-full">
                <ServiceCard
                  image={service.image}
                  title={service.title}
                  lead={service.lead}
                  description={service.description}
                />
              </div>
            ))
        }
      </div>
    </div>
    <!--div class="service-anim-item flex justify-center max-md:justify-stretch">
      <Button
        label="Conoce más acerca de mis servicios"
        iconRight="icon-right-arrow"
        type="button"
        size="lg"
      />
    </div-->
  </div>
</Section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const root = document.querySelector(".service-section-root");
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (root && !reduceMotion) {
    const tl = gsap.timeline({
      scrollTrigger: { trigger: root, start: "top 78%", once: true },
    });

    tl.from(root.querySelectorAll(".service-anim-item"), {
      opacity: 0,
      y: 28,
      duration: 1,
      stagger: 0.12,
      ease: "power2.out",
    });

    tl.from(
      root.querySelectorAll(".service-card-anim-item"),
      { opacity: 0, y: 36, duration: 0.8, stagger: 0.1, ease: "power2.out" },
      "-=0.6",
    );
  }
</script>
