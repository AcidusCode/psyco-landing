---
import MainHeroData from "../../data/MainHeroData.json";
import Image from "astro/components/Image.astro";
import coverImage from "../../assets/image/Cover-Image.png";
import TestimonialsBadge from "../molecules/TestimonialsBadge.astro";
import Button from "../atoms/Button.astro";

import SectionHeaderHero from "../molecules/SectionHeaderHero.astro";
import Paragraph from "../typography/body/Paragraph.astro";
---
<section class="flex relative flex-col items-center">
  <Image
    src={coverImage}
    alt="Cover Image"
    class="absolute bottom-0 z-0 h-full w-full object-cover object-center select-none pointer-events-none"
  />

  <div class="flex flex-col z-10 gap-12 pt-40 pb-20 w-full max-w-[1420px]">
    <SectionHeaderHero
      lead={MainHeroData.Lead}
      heading={MainHeroData.Title}
      body={MainHeroData.Description}
    />

    <div class="flex flex-col gap-4">
      <div class="flex gap-4 items-center">
        <Button
          intent="primary"
          variant="solid"
          iconRight="icon-right-arrow"
          size="md"
          label={MainHeroData.Cta}
          area-disabled="true"
        />
        <Paragraph size="md" text={MainHeroData.AuxCta} />
      </div>

      <TestimonialsBadge />
    </div>
  </div>
</section>
