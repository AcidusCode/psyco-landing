---
import Heading2 from "../typography/headings/Heading2.astro";
import Section from "./Section.astro";
import CheckMarkIcon from "../../assets/icons/benefits-icons/checkmark-circle-outline.svg";
import ClipBoardIcon from "../../assets/icons/benefits-icons/clipboard-outline.svg";
import EarthIcon from "../../assets/icons/benefits-icons/earth-outline.svg";
import PeopleIcon from "../../assets/icons/benefits-icons/people-outline.svg";
import IconSvg from "../atoms/IconSvg.astro";
import Image from "astro/components/Image.astro";
import Paragraph from "../typography/body/Paragraph.astro";
---

<Section>
  <Heading2 text="Lo que ganarás con \n este acompañamiento" align="center" />
  <div class="flex w-full justify-around max-w-5xl text-center">
    <div class="flex flex-col items-center">
      <Image src={PeopleIcon} alt="Icono de checkmark" class="w-30 h-30" />
      <Paragraph
        size="md"
        text="Resultados visibles \n desde el primer día"
        align="center"
      />
    </div>
    <div class="flex flex-col items-center">
      <Image src={EarthIcon} alt="Icono de checkmark" class="w-30 h-30" />
      <Paragraph
        size="md"
        text="Resultados visibles \n desde el primer día"
        align="center"
      />
    </div>
    <div class="flex flex-col items-center">
      <Image src={CheckMarkIcon} alt="Icono de checkmark" class="w-30 h-30" />
      <Paragraph
        size="md"
        text="Resultados visibles \n desde el primer día"
        align="center"
      />
    </div>
    <div class="flex flex-col items-center">
      <Image src={ClipBoardIcon} alt="Icono de checkmark" class="w-30 h-30" />
      <Paragraph
        size="md"
        text="Resultados visibles \n desde el primer día"
        align="center"
      />
    </div>
  </div>
</Section>
