---
import Image from "astro/components/Image.astro";
import avatar from "../../assets/image/testimonials/avatar.png";
import avatar2 from "../../assets/image/testimonials/avatar2.png";
import avatar3 from "../../assets/image/testimonials/avatar3.png";
---

<div
  class="flex testimonials-badge pl-4 pr-8 py-4 rounded-full font-medium items-center gap-2"
>
  <p>
    10+ Años de Expericia
  </p>
  <div class="flex testimonials-badge-container-images items-center translate-x-[15%]">
    <Image
      src={avatar}
      alt="Avatar"
      class="w-11 h-11 rounded-full border-2 z-10"
    />
    <Image
      src={avatar2}
      alt="Avatar"
      class="w-11 h-11 rounded-full border-2 transform -translate-x-[30%] z-9"
    />
    <Image
      src={avatar3}
      alt="Avatar"
      class="w-11 h-11 rounded-full border-2 transform -translate-x-[60%] z-8"
    />
  </div>

  <div class="flex flex-col text-left">
    <p class="font-extrabold">+50 clientes satisfechos.</p>
    <!--p>★★★★★</p-->
    <p class="font-thin">Unete y comencemos a transformar tu vida.</p>
  </div>
</div>

<style>
  .testimonials-badge {
    color: var(--color-black);
  }
  .testimonials-badge-container-images {
    color: var(--color-white);
    border-left: 2px solid var(--color-gray-300);
    padding-left: var(--spacing-600);
  }
</style>