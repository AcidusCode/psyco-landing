---
import Image from "astro/components/Image.astro";
import testimonialImage from "../../../assets/image/testimonials/avatar.png";
import Paragraph from "../../typography/body/Paragraph.astro";
import IconSvg from "../../atoms/IconSvg.astro";
import StarsRanking from "../StarsRanking.astro";

const {
  image = testimonialImage,
  name = "Nombre testimonio",
  service = "Acompañamiento individual",
  rating = 5,
  countryIcon = "icon-flag-colombia",
  quote = "Tuve una muy buena experiencia con un profesional sólido en su rol, que me ayudo a ver mi autenticidad, mi capacidad de entrega a instancias comunitarias desde una sanidad individual.",
} = Astro.props;
---

<article
  class="flex flex-col max-w-[452px] px-8 py-6 gap-2 bg-neutral-800 rounded-xl"
>
  <header class="flex items-center justify-between gap-4">
    <div class="flex items-center gap-4">
      <Image
        src={image}
        alt="Imagen de testimonio"
        width={80}
        height={80}
        class="w-full max-w-20 max-h-20 rounded-lg"
      />
      <div class="flex flex-col mt-4 mb-6">
        <Paragraph
          size="md"
          text={name}
          weight="regular"
          color="text-neutral-100"
        />
        <Paragraph
          size="sm"
          text={service}
          weight="light"
          color="text-neutral-200"
        />
        <div class="flex gap-2 items-center">
          <StarsRanking rating={rating} />
          <Paragraph size="sm" text={rating} class="inline-block ml-2" />
        </div>
      </div>
    </div>
    <div class="flex flex-col gap-4">
      <IconSvg name={countryIcon} set="flag-icons" size={32} />
      <div
        class="flex items-center justify-center w-8 h-8 bg-neutral-700 rounded-full"
      >
        <IconSvg name="icon-quotes" size={16} stroke="none" />
      </div>
    </div>
  </header>
  <main>
    <Paragraph
      size="md"
      text={quote}
      weight="light"
      classes="line-clamp-5"
      color="text-neutral-200"
    />
  </main>
</article>
