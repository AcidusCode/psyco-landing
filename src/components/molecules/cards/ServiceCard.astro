---
import LeadText from "../../typography/specials/LeadText.astro";
import Paragraph from "../../typography/body/Paragraph.astro";

const {
  image = "/services/individual.png",
  title = "Acompañamiento psicológico individual",
  lead = "Ideal para quienes buscan claridad emocional.",
  description = "Un espacio seguro para entenderte y sanar. Te acompaño con enfoque humano y personalizado.",
} = Astro.props;
---

<article
  class="service-card flex flex-col overflow-hidden"
>
  <img
    src={image}
    alt="Imagen de consultoría psicológica"
    class="max-h-[250px] object-cover object-center"
  />
  <div class="flex flex-col px-6 py-4">
    <Paragraph size="lg" text={title} color="text-neutral-100"/>
    <Paragraph size="md" text={description} color="text-neutral-300" weight="light" />
  </div>
</article>

<style>
  .service-card {
    background-color: rgba(100,100,100,.05);
    border-radius: 24px;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.10), 0 4px 6px -4px rgba(0, 0, 0, 0.10);
    transition: all 0.3s ease-in-out;
    border: 3px solid transparent;
  }
  .service-card:hover {
    transform: scale(1.04);
    border: 3px solid var(--color-primary-400);
  }
  .service-card-title {
    color: var(--color-text-headings);
  }
  .service-card-description {
    color: var(--color-text-body);
  }
</style>