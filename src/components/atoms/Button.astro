    --btn-bg-ghost: var(--button-primary-bg-ghost);
    --btn-bg-outline: var(--button-primary-outline-bg);
    --btn-text: var(--button-primary-text);
    --btn-text-ghost: var(--button-primary-ghost-text);
    --btn-text-outline: var(--button-primary-outline-text);
    --btn-border: var(--button-primary-border);
    --btn-border-ghost: var(--button-primary-ghost-border-focus);
    --btn-border-outline: var(--button-primary-outline-border-focus);

    --btn-bg-hover: var(--button-primary-bg-hover);
    --btn-text-hover: var(--button-primary-text-hover);
    --btn-text-hover-outline: var(--button-primary-outline-text-hover);
    --btn-text-hover-ghost: var(--button-primary-text-hover);
    --btn-border-hover: var(--button-primary-border-hover);
    --btn-border-hover-ghost: var(--button-primary-ghost-border-hover);
    --btn-border-hover-outline: var(--button-primary-outline-border-hover);

    --btn-bg-active: var(--button-primary-bg-press);
    --btn-text-active: var(--button-primary-text-press);
    --btn-border-active: var(--button-primary-border-press);

