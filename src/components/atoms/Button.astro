---
interface Props {
  variant?: "solid" | "ghost" | "outline";
  intent?:
    | "primary"
    | "secondary"
    | "success"
    | "warning"
    | "error"
    | "info"
    | "neutral"
    | "on-action";
  size?: "sm" | "md" | "lg";
  isLoading?: boolean;
  disabled?: boolean;
  iconLeft?: string;
  iconRight?: string;
  type?: "button" | "submit" | "reset";
  label?: string;
}

const {
  variant = "solid",
  intent = "primary",
  size = "md",
  isLoading = false,
  disabled = false,
  iconLeft,
  iconRight,
  type = "button",
  label = "Label Button",
} = Astro.props;

const state = disabled ? "disabled" : isLoading ? "loading" : "default";
import IconSvg from "./IconSvg.astro";
---

<button
  type={type}
  class="button-base"
  data-variant={variant}
  data-intent={intent}
  data-size={size}
  data-state={state}
  disabled={disabled}
>
  {iconLeft && <IconSvg name={iconLeft} />}
  {label}
  {iconRight && <IconSvg name={iconRight} />}
</button>

<style>
  /* ==========================================================
   1. BASE DEL BOTÓN
========================================================== */

  .button-base {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--button-gap);
    padding: var(--button-padding-y) var(--button-padding-x);
    border: 1px solid transparent;
    border-radius: var(--button-radius);
    font-size: var(--button-font-size);
    font-weight: var(--button-font-weight);
    transition:
      background-color 0.3s ease,
      border-color 0.3s ease,
      color 0.3s ease,
      scale 0.2s ease;
    cursor: pointer;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.10), 0 4px 6px -4px rgba(0, 0, 0, 0.10);
  }

  /* ==========================================================
   1.5. SIZE (Sm, Md, Lg)
========================================================== */

  [data-size="sm"] {
    padding: var(--button-padding-y-sm) var(--button-padding-x-sm);
    font-size: var(--button-font-size-sm);
  }
  [data-size="md"] {
    padding: var(--button-padding-y-md) var(--button-padding-x-md);
    font-size: var(--button-font-size-md);
  }
  [data-size="lg"] {
    padding: var(--button-padding-y-lg) var(--button-padding-x-lg);
    font-size: var(--button-font-size-lg);
  }

  /* ==========================================================
   2. VARIANTES (Solid, Ghost, Outline)
========================================================== */

  [data-variant="solid"] {
    background: linear-gradient(to right, var(--color-primary-500), var(--color-secondary-500));
    color: var(--color-white);
    border: 1px solid var(--color-border-disabled);
  }

  [data-variant="solid"][data-intent="on-action"] {
    background: var(--btn-bg);
    color: var(--btn-text);
    border: 1px solid var(--btn-border);
  }

  [data-variant="solid"]:hover {
    background: linear-gradient(to right, var(--color-primary-600), var(--color-secondary-500));
    border: 1px solid var(--color-border-disabled-weak);
    color: var(--color-white);
    scale: 1.03;
  }

  [data-variant="solid"][data-intent="on-action"]:hover {
    background: var(--btn-bg-hover);
    color: var(--btn-text-hover);
    border: 1px solid var(--btn-border-hover);
    scale: 1.03;
  }

  [data-variant="solid"]:active {
    background: var(--btn-bg-active);
    color: var(--btn-text-active);
    border-color: var(--btn-border-active);
  }

  [data-variant="solid"]:focus {
    background: var(--btn-bg-focus);
    color: var(--btn-text-focus);
    border-color: var(--btn-border-focus);
  }

  [data-variant="solid"]:focus::after {
    content: "";
    position: absolute;
    inset: -6px; 
    border-radius: inherit;
    border: 3px solid var(--btn-focus-ring);
    pointer-events: none;
  }


  [data-variant="ghost"] {
    background: rgba(100,100,100,.2);
    border: 1px solid var(--btn-border-ghost);
    color: var(--color-text-headings);
  }

  [data-variant="ghost"]:hover {
    background: rgba(100,100,100,.4);
    border: 1px solid var(--btn-border-hover-ghost);
    color: var(--btn-text-hover-ghost);
  }

  [data-variant="ghost"]:active {
    background: var(--btn-bg-active);
    color: var(--btn-text-active);
    border-color: var(--btn-border-active);
  }

  [data-variant="ghost"]:focus {
    background: transparent;
    color: var(--btn-text-focus-ghost);
    border-color: var(--btn-border-focus);
  }

  [data-variant="ghost"]:focus::after {
    content: "";
    position: absolute;
    inset: -6px; 
    border-radius: inherit;
    border: 3px solid var(--btn-focus-ring);
    pointer-events: none;
  }

  [data-variant="outline"] {
    background: (var(--btn-bg-outline));
    border: 1px solid var(--btn-border-outline);
    color: var(--btn-text-outline);
  }

  [data-variant="outline"]:hover {
    background: var(--btn-bg-hover);
    border: 1px solid var(--btn-border-hover-outline);
    color: var(--btn-text-hover-outline);
  }

  [data-variant="outline"]:active {
    background: var(--btn-bg-active);
    color: var(--btn-text-active);
    border-color: var(--btn-border-active);
  }

  [data-variant="outline"]:focus {
    background: transparent;
    color: var(--btn-text-focus-outline);
    border-color: var(--btn-border-focus);
  }

  [data-variant="outline"]:focus::after {
    content: "";
    position: absolute;
    inset: -6px; 
    border-radius: inherit;
    border: 3px solid var(--btn-focus-ring);
    pointer-events: none;
  }

  /* ==========================================================
   3. INTENTS (Primario, Warning, etc.)
========================================================== 
*/

  [data-intent="primary"] {
