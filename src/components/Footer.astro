---
import Paragraph from "./typography/body/Paragraph.astro";
---

<footer
  class="footer-root relative flex flex-col w-full max-w-7xl mx-auto px-6 md:px-5 max-md:px-4 pt-16 md:pt-12 max-md:pt-10 pb-8 md:pb-6 max-md:pb-5 mb-10 md:mb-8 max-md:mb-6 gap-8 md:gap-6 max-md:gap-5"
>
  <div class="footer-top relative grid grid-cols-3 md:grid-cols-2 max-md:grid-cols-1 gap-10 md:gap-8 max-md:gap-6">
    <div class="flex flex-col gap-4 md:gap-3 max-md:gap-2.5">
      <Paragraph
        text="Psicólogo Diego Moreno"
        weight="semibold"
        classes="md:text-paragraph-md md:leading-paragraph-md max-md:text-paragraph-md max-md:leading-paragraph-md"
      />
      <Paragraph
        text="Psicólogo especializado en salud \n mental, esta aquí para ayudarte a \n alcanzar el bienestar mental."
        classes="footer-description max-md:text-paragraph-sm max-md:leading-paragraph-sm"
      />
    </div>
    <div class="flex flex-col gap-4 md:gap-3 max-md:gap-2.5">
      <Paragraph
        text="Horario de Oficina"
        size="md"
        weight="semibold"
        classes="max-md:text-paragraph-sm max-md:leading-paragraph-sm"
      />
      <div class="flex gap-2">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 18 18"
          fill="none"
        >
          <path
            d="M15 7.5C15 11.2448 10.8457 15.1447 9.45075 16.3492C9.32079 16.447 9.1626 16.4998 9 16.4998C8.8374 16.4998 8.67921 16.447 8.54925 16.3492C7.15425 15.1447 3 11.2448 3 7.5C3 5.9087 3.63214 4.38258 4.75736 3.25736C5.88258 2.13214 7.4087 1.5 9 1.5C10.5913 1.5 12.1174 2.13214 13.2426 3.25736C14.3679 4.38258 15 5.9087 15 7.5Z"
            stroke="#101828"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
          <path
            d="M9 9.75C10.2426 9.75 11.25 8.74264 11.25 7.5C11.25 6.25736 10.2426 5.25 9 5.25C7.75736 5.25 6.75 6.25736 6.75 7.5C6.75 8.74264 7.75736 9.75 9 9.75Z"
            stroke="#101828"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        <ul class="footer-list flex flex-col gap-2 max-md:gap-1.5">
          <li>Lunes - Viernes: 9am - 7pm</li>
          <li>Sábado: 10am - 4pm</li>
          <li>Domingo: Cerrado</li>
          <li>Citas nocturnas disponibles</li>
        </ul>
      </div>
    </div>
    <div class="flex flex-col gap-4 md:gap-3 max-md:gap-2.5">
      <Paragraph
        text="Ubicación"
        size="md"
        weight="semibold"
        classes="max-md:text-paragraph-sm max-md:leading-paragraph-sm"
      />
      <div class="flex gap-2">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 18 18"
          fill="none"
        >
          <path
            d="M15 7.5C15 11.2448 10.8457 15.1447 9.45075 16.3492C9.32079 16.447 9.1626 16.4998 9 16.4998C8.8374 16.4998 8.67921 16.447 8.54925 16.3492C7.15425 15.1447 3 11.2448 3 7.5C3 5.9087 3.63214 4.38258 4.75736 3.25736C5.88258 2.13214 7.4087 1.5 9 1.5C10.5913 1.5 12.1174 2.13214 13.2426 3.25736C14.3679 4.38258 15 5.9087 15 7.5Z"
            stroke="#101828"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
          <path
            d="M9 9.75C10.2426 9.75 11.25 8.74264 11.25 7.5C11.25 6.25736 10.2426 5.25 9 5.25C7.75736 5.25 6.75 6.25736 6.75 7.5C6.75 8.74264 7.75736 9.75 9 9.75Z"
            stroke="#101828"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        <ul class="footer-list flex flex-col gap-2 max-md:gap-1.5">
          <li>Bogota</li>
          <li>Cundinamarca</li>
          <li>Colombia</li>
        </ul>
      </div>
    </div>
  </div>
  <div class="p-8 md:p-6 max-md:p-4 border-t border-gray-300">
    <Paragraph
      text="Diseñado y desarrollado por AcidusLabs"
      size="sm"
      align="center"
      classes="max-md:text-[11px] max-md:leading-[16px]"
    />
  </div>
</footer>

<style>
  .footer-list {
    color: var(--color-text-body);
    font-size: var(--font-body-text-size);
    line-height: var(--font-body-line-height);
  }

  @media (max-width: 1024px) {
    .footer-list {
      font-size: 14px;
      line-height: 20px;
    }

    .footer-description {
      max-width: 52ch;
    }
  }

  @media (max-width: 768px) {
    .footer-top {
      gap: 20px;
    }

    .footer-list {
      font-size: 13px;
      line-height: 18px;
    }

    .footer-description {
      max-width: 42ch;
    }
  }
</style>
